generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id        String   @id @default(uuid())

  name      String
  email     String?
  phone     String?

  owner     String?
  service   String?

  source    String
  status    String   @default("NEW")

  value     Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([owner])
  @@index([source])
  @@index([service])
  @@index([status])
  @@index([createdAt])
}