generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id        String   @id @default(uuid())

  name      String
  email     String?
  phone     String?

  owner     String?
  service   String?

  source    String
  status    String   @default("NEW")

  value     Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audits    EnquiryAudit[]

  @@index([owner])
  @@index([source])
  @@index([service])
  @@index([status])
  @@index([createdAt])
}

model EnquiryAudit {
  id         String   @id @default(uuid())

  enquiryId  String
  oldStatus  String
  newStatus  String

  changedAt  DateTime @default(now())

  enquiry    Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([enquiryId])
  @@index([changedAt])
}